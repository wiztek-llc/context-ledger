#!/usr/bin/env python3
"""ctxledger — live Context Ledger CLI for Claude Code (dependency-free: git + stdlib).

Commands:
  ctxledger record   [--repo R] [--ledger F]   extract HEAD commit -> append a ledger entry
  ctxledger show     [--ledger F]               print the current ledger
  ctxledger rehydrate <ref> [--repo R]          recover exact detail from git (git show)
  ctxledger stats    [--ledger F]               entry count / size

The ledger file is the DURABLE, restorable memory: compact structured entries
(commit message + public interfaces + a git SHA pointer) that survive context
compaction. Default ledger: $CLAUDE_PROJECT_DIR/.claude/context-ledger.md
"""
import argparse
import json
import os
import re
import subprocess
import sys

# source extensions whose full content an agent would hold in context while
# building (mirrors the benchmark's build-context model); docs excluded.
_SRC = (".py", ".sh", ".json", ".js", ".ts", ".tsx", ".jsx", ".go", ".rs",
        ".c", ".h", ".cpp", ".java", ".rb", ".swift", ".kt", ".php", ".css")


def _est_tokens(text):
    """Dependency-free token estimate (~4 chars/token) for the live display."""
    return max(0, round(len(text) / 4))

_SIG = re.compile(r"^\+\s*((?:def|class|async def)\s+[A-Za-z_]\w*\s*\([^)]*\)"
                  r"|[A-Z_][A-Z0-9_]+\s*=)", re.M)


def git(repo, *args):
    return subprocess.run(["git", "-C", repo, *args],
                          capture_output=True, text=True).stdout


def default_repo():
    return os.environ.get("CLAUDE_PROJECT_DIR") or os.getcwd()


def _toplevel(d):
    """git root of d, so the ledger lives at the repo root regardless of which
    subdirectory the commit ran from. Falls back to d if d isn't in a repo."""
    return git(d, "rev-parse", "--show-toplevel").strip() or d


def default_ledger(repo):
    return os.path.join(_toplevel(repo), ".claude", "context-ledger.md")


def interfaces(diff, limit=14):
    seen, out = set(), []
    for m in _SIG.finditer(diff):
        sig = re.sub(r"\s+", " ", m.group(1)).strip().rstrip("=").strip()
        if sig not in seen:
            seen.add(sig); out.append(sig)
        if len(out) >= limit:
            break
    return out


def entry_for(repo, ref="HEAD"):
    sha = git(repo, "rev-parse", ref).strip()
    if not sha:
        return None
    subject = git(repo, "show", "-s", "--format=%s", sha).strip()
    body = git(repo, "show", "-s", "--format=%b", sha).strip()
    files = [f for f in git(repo, "show", "--name-only", "--format=", sha).split("\n") if f.strip()]
    diff = git(repo, "show", "--format=", sha)
    ifaces = "\n".join(f"    - {s}" for s in interfaces(diff)) or "    - (none)"
    return (
        f"### {subject}  [commit {sha[:8]}]\n"
        f"{body}\n"
        f"  public interfaces:\n{ifaces}\n"
        f"  files: {', '.join(files)}\n"
        f"  rehydrate: git show {sha[:8]}  (or {sha[:8]}:<path>)\n"
    )


def raw_context_tokens(repo, sha):
    """Estimate the raw build-context tokens this commit would otherwise occupy:
    commit message + diff + the full content of the changed source files read."""
    subject = git(repo, "show", "-s", "--format=%s", sha)
    body = git(repo, "show", "-s", "--format=%b", sha)
    diff = git(repo, "show", "--format=", sha)
    files = [f for f in git(repo, "show", "--name-only", "--format=", sha).split("\n")
             if f.strip() and f.endswith(_SRC)]
    text = subject + body + diff
    for p in files[:12]:
        text += git(repo, "show", f"{sha}:{p}")
    return _est_tokens(text)


def update_stats(repo, raw, entry):
    path = os.path.join(_toplevel(repo), ".claude", "context-ledger.stats.json")
    s = {"features": 0, "raw_tokens": 0, "entry_tokens": 0, "saved_tokens": 0}
    if os.path.isfile(path):
        try:
            s.update(json.load(open(path)))
        except Exception:
            pass
    s["features"] += 1
    s["raw_tokens"] += raw
    s["entry_tokens"] += entry
    s["saved_tokens"] = s["raw_tokens"] - s["entry_tokens"]
    json.dump(s, open(path, "w"))
    return s


def cmd_record(a):
    repo = a.repo or default_repo()
    ledger = a.ledger or default_ledger(repo)
    sha = git(repo, "rev-parse", "HEAD").strip()
    os.makedirs(os.path.dirname(ledger), exist_ok=True)
    # idempotent: skip if this SHA already recorded
    if os.path.isfile(ledger) and f"[commit {sha[:8]}]" in open(ledger).read():
        return
    e = entry_for(repo)
    if not e:
        return
    header = "" if os.path.isfile(ledger) else (
        "# Context Ledger\n\nCompacted feature memory. Each entry is the restorable "
        "record of a committed feature; recover full detail with `git show <sha>`.\n\n")
    with open(ledger, "a") as f:
        if header:
            f.write(header)
        f.write(e + "\n")
    raw = raw_context_tokens(repo, sha)
    update_stats(repo, raw, _est_tokens(e))
    sys.stdout.write(e)


def cmd_show(a):
    ledger = a.ledger or default_ledger(default_repo())
    sys.stdout.write(open(ledger).read() if os.path.isfile(ledger) else "")


def cmd_rehydrate(a):
    repo = a.repo or default_repo()
    ref = a.ref if not a.path else f"{a.ref}:{a.path}"
    sys.stdout.write(git(repo, "show", ref))


def _human(n):
    if n >= 1_000_000:
        return f"{n / 1e6:.1f}M"
    if n >= 1_000:
        return f"{n / 1e3:.0f}k"
    return str(int(n))


def cmd_doctor(a):
    import shutil
    repo = a.repo or default_repo()
    print("Context Ledger — doctor\n")
    top = git(repo, "rev-parse", "--show-toplevel").strip()
    is_git = bool(top)
    ok = lambda b: "\033[32m ok \033[0m" if b else "\033[31mMISS\033[0m"
    print(f"  [{ok(is_git)}] git repo            {top or '(this dir is NOT a git repo — nothing to record)'}")
    cli = shutil.which("ctxledger")
    print(f"  [{ok(bool(cli))}] ctxledger on PATH   {cli or '(not on PATH)'}")

    settings = os.path.expanduser("~/.claude/settings.json")
    commit_hook = inject_hook = False
    try:
        d = json.load(open(settings))
        cmds = [h.get("command", "") for ev in ("PostToolUse", "SessionStart")
                for g in d.get("hooks", {}).get(ev, []) for h in g.get("hooks", [])]
        commit_hook = any("ledger-commit" in c for c in cmds)
        inject_hook = any("ledger-inject" in c for c in cmds)
    except Exception:
        pass
    print(f"  [{ok(commit_hook)}] commit hook         records when a Bash `git commit` is seen")
    print(f"  [{ok(inject_hook)}] session hook        re-injects the ledger at session start")
    githook = False
    if is_git:
        hp = git(repo, "rev-parse", "--git-path", "hooks").strip()
        if hp and not os.path.isabs(hp):
            hp = os.path.join(top, hp)
        pc = os.path.join(hp, "post-commit") if hp else ""
        githook = bool(pc) and os.path.isfile(pc) and "context-ledger" in open(pc).read()
    star = lambda b: "\033[32m ok \033[0m" if b else " ·· "
    print(f"  [{star(githook)}] git post-commit     records EVERY commit (even via make/deploy/IDE)")

    ledger = default_ledger(repo)
    n = open(ledger).read().count("[commit ") if os.path.isfile(ledger) else 0
    stats = os.path.join(top or repo, ".claude", "context-ledger.stats.json")
    saved = 0
    if os.path.isfile(stats):
        try:
            saved = json.load(open(stats)).get("saved_tokens", 0)
        except Exception:
            pass
    star = lambda b: "\033[32m ok \033[0m" if b else " ·· "
    print(f"  [{star(n)}] features recorded   {n}")
    print(f"  [{star(saved)}] context saved       ~{saved:,} tokens")

    print()
    head = git(repo, "rev-parse", "--short", "HEAD").strip() if is_git else ""
    if not is_git:
        print("  → Not a git repo here, so there's nothing for the ledger to compact.")
    elif not (commit_hook and inject_hook):
        print("  → Hooks not installed. Run the project's ./install.sh --with-hooks,")
        print("    then RESTART this Claude Code session (hooks load at session start).")
    elif n == 0 and head:
        print("  → Wired up, but nothing recorded yet. Two ways to see it work NOW:")
        print("      1) ctxledger record      (captures the current HEAD commit)")
        print("      2) make your next commit (records automatically)")
        print("    then:  ctxledger show   /   ctxledger stats")
    elif n == 0:
        print("  → Wired up. Make your first commit and it records automatically.")
    else:
        print(f"  → Working. {n} features recorded, ~{_human(saved)} tokens saved.")
        print(f"    Ledger: {ledger}")
        print(f"    The status line shows '⊟ {_human(saved)} ctx saved' when Claude Code")
        print(f"    runs in this project (it reads {os.path.relpath(stats, top or repo)}).")
    if is_git and not githook:
        print("\n  Tip: for bulletproof recording (commits via make/deploy/IDE, not just")
        print("  `git commit`), run:  ctxledger install-git-hook")
    if commit_hook:
        print("\n  Note: the Claude Code hooks load at SESSION START. If you installed them")
        print("  while this session was already open, restart it once to activate them.")


def cmd_install_git_hook(a):
    """Install a git post-commit hook so EVERY commit records — regardless of how
    it's made (git, make ship, deploy.sh, IDE). Idempotent; preserves any
    existing post-commit hook."""
    repo = a.repo or default_repo()
    hooks_dir = git(repo, "rev-parse", "--git-path", "hooks").strip()
    if not hooks_dir:
        print("✗ not a git repo"); return
    if not os.path.isabs(hooks_dir):
        hooks_dir = os.path.join(_toplevel(repo), hooks_dir)
    os.makedirs(hooks_dir, exist_ok=True)
    path = os.path.join(hooks_dir, "post-commit")
    cli = os.path.abspath(sys.argv[0])
    block = ('\n# >>> context-ledger >>>\n'
             f'"{cli}" record --repo "$(git rev-parse --show-toplevel 2>/dev/null)" '
             '>/dev/null 2>&1 || true\n# <<< context-ledger <<<\n')
    existing = open(path).read() if os.path.isfile(path) else ""
    if "context-ledger" in existing:
        print(f"✓ git post-commit hook already installed ({path})"); return
    with open(path, "a" if existing else "w") as f:
        if not existing:
            f.write("#!/bin/sh\n")
        f.write(block)
    os.chmod(path, 0o755)
    print(f"✓ git post-commit hook installed → {path}")
    print("  Every commit in this repo now records to the ledger automatically.")


def cmd_stats(a):
    repo = a.repo or default_repo()
    stats = os.path.join(_toplevel(repo), ".claude", "context-ledger.stats.json")
    if not os.path.isfile(stats):
        print("0 features recorded"); return
    s = json.load(open(stats))
    saved = s.get("saved_tokens", 0)
    ratio = (s["raw_tokens"] / s["entry_tokens"]) if s.get("entry_tokens") else 0
    print(f"{s['features']} features  |  ~{saved:,} context tokens saved  "
          f"(~{s['raw_tokens']:,} raw -> ~{s['entry_tokens']:,} in ledger, {ratio:.0f}x)")


def main():
    p = argparse.ArgumentParser(prog="ctxledger")
    sub = p.add_subparsers(dest="cmd", required=True)
    for name in ("record", "show", "stats", "doctor", "install-git-hook"):
        s = sub.add_parser(name); s.add_argument("--repo"); s.add_argument("--ledger")
    r = sub.add_parser("rehydrate"); r.add_argument("ref"); r.add_argument("path", nargs="?")
    r.add_argument("--repo"); r.add_argument("--ledger")
    a = p.parse_args()
    {"record": cmd_record, "show": cmd_show, "rehydrate": cmd_rehydrate,
     "stats": cmd_stats, "doctor": cmd_doctor,
     "install-git-hook": cmd_install_git_hook}[a.cmd](a)


if __name__ == "__main__":
    main()
